{
  "name": "project-starter",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "preview": "vp run -r --parallel preview",
    "clear": "vp run -r clear && pnpx rimraf@^6.0.1 -g '**/coverage' '**/node_modules'",
    "prepare": "vp config",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@project-starter/shared": "workspace:*",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:test",
    "eslint": "catalog:lint",
    "jiti": "catalog:build",
    "typescript": "catalog:types",
    "vite-plus": "catalog:build",
    "vitest": "catalog:"
  }
}
